# =============================================================================
# Rice Vision — Edge Client Environment
# Shipped inside the .deb. Postinstall copies this to ~/.config/Hum.ai/.env
# on first install. Operator completes provisioning via the in-app Setup screen.
# =============================================================================

# ── Device identity (auto-filled by Setup screen) ─────────────────────────────
# All four are written by the SetupPage after a successful cloud provision.
# Leave empty on a fresh install.
DEVICE_ID=
DEVICE_SECRET=
DEVICE_DISPLAY_NAME=
DEVICE_QR_URL=

# ── API server ────────────────────────────────────────────────────────────────
API_BASE_URL=https://hum-ai-zq6h9.ondigitalocean.app
API_TIMEOUT_SECONDS=30

# ── Local paths ───────────────────────────────────────────────────────────────
# Defaults compute under app userData dir if left empty.
IMAGE_DIR=
LOG_DIR=
CAPTURE_LOCK_FILE=/tmp/edge-capture.lock

# ── Mode switch ───────────────────────────────────────────────────────────────
# production : grading pipeline (uploads to api-server)
# training   : data collection (uploads to Roboflow via api-server)
EDGE_MODE=production
PRODUCTION_UPLOAD_TARGET=api
TRAINING_UPLOAD_TARGET=roboflow

# ── Roboflow (only if Pi uploads training images directly; usually unused) ────
# The api-server has its own Roboflow keys for the upload-training endpoint.
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=
ROBOFLOW_PROJECT_NORMAL=
ROBOFLOW_PROJECT_IR=

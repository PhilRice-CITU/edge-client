# =============================================================================
# Rice Vision — Edge Client Environment
# Shipped inside the .deb. Postinstall copies this to ~/.config/Hum.ai/.env
# on first install. Operator completes provisioning via the in-app Setup screen.
# =============================================================================

# ── Device identity (auto-filled by Setup screen) ─────────────────────────────
# All four are written by the SetupPage after a successful cloud provision.
# Leave empty on a fresh install.
DEVICE_ID=
DEVICE_SECRET=
DEVICE_DISPLAY_NAME=
DEVICE_QR_URL=

# ── API server ────────────────────────────────────────────────────────────────
API_BASE_URL=https://hum-ai-api.onrender.com
API_TIMEOUT_SECONDS=30

# ── Local paths ───────────────────────────────────────────────────────────────
# Defaults compute under app userData dir if left empty.
IMAGE_DIR=
LOG_DIR=
CAPTURE_LOCK_FILE=/tmp/edge-capture.lock

# ── Mode switch ───────────────────────────────────────────────────────────────
# production : grading pipeline (uploads to api-server)
# training   : data collection (uploads to Roboflow via api-server)
EDGE_MODE=production
PRODUCTION_UPLOAD_TARGET=api
TRAINING_UPLOAD_TARGET=roboflow

# ── Roboflow (only if Pi uploads training images directly; usually unused) ────
# The api-server has its own Roboflow keys for the upload-training endpoint.
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=
ROBOFLOW_PROJECT_NORMAL=
ROBOFLOW_PROJECT_IR=

# ── MQTT live connection ──────────────────────────────────────────────────────
MQTT_HOST=broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_TOPIC_PREFIX=ricevision
MQTT_KEEPALIVE_SECONDS=30
MQTT_TELEMETRY_INTERVAL_SECONDS=15
MQTT_CLIENT_ID=

# ── Camera preview tuning (optional; sensible defaults baked in) ──────────────
# Only override if the Pi camera struggles with the defaults.
# PREVIEW_FRAME_WIDTH=640
# PREVIEW_FRAME_HEIGHT=480
# PREVIEW_FRAME_DURATION_MS=700
# PREVIEW_FRAME_TIMEOUT_SECONDS=6

# ── Safety: power commands over MQTT ──────────────────────────────────────────
# Set to 'true' to allow remote shutdown/reboot via the cloud command channel.
# Leave 'false' on production devices unless you trust the operator.
ALLOW_POWER_COMMANDS=false

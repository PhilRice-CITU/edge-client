# =============================================================================
# Rice Vision — Edge Client Environment (edge-client/.env)
# Copy to .env and fill in the values before running startup.sh or setup.sh
# =============================================================================

# ── Device identity ───────────────────────────────────────────────────────────
# Unique ID for this Pi — AUTO-SET by provision.py on first boot, do not fill manually
DEVICE_ID=82b6db49-9fd7-454f-a21b-62fecbd3f6c5
# Secret used by command-consumer when polling authenticated device commands.
# Optional for now; leave empty unless your API server issues one for this device.
DEVICE_SECRET=

# ── Auto-provisioning ──────────────────────────────────────────────────────────────
# On first boot, if DEVICE_ID is empty, provision.py will call POST /devices/provision
# and write DEVICE_ID back to this file automatically.
#
# PROVISION_TOKEN  — shared secret set by the admin in the API server's .env
# REGION_CODE      — short code of the region this Pi belongs to (e.g. 'cebu', 'manila')
#                    must match a region already created in the database
PROVISION_TOKEN=
REGION_CODE=
# Human-readable name auto-assigned during provisioning (e.g. cebu-001), do not edit
DEVICE_DISPLAY_NAME=test-raspberry-01

# ── API server ────────────────────────────────────────────────────────────────
# Base URL of the Rice Vision API (no trailing slash)
API_BASE_URL=https://your-api-server.com
# Path to post scan uploads to
API_UPLOAD_PATH=/scans
# Path for heartbeat pings
API_HEARTBEAT_PATH=/devices/heartbeat
# Path template for edge result status polling (device-authenticated)
API_RESULT_STATUS_PATH_TEMPLATE=/devices/{device_id}/results/{result_id}/status
# Path template for preview request state polling (device-authenticated)
API_PREVIEW_REQUEST_PATH_TEMPLATE=/devices/{device_id}/preview/request
# Path template for preview frame uploads (device-authenticated)
API_PREVIEW_UPLOAD_PATH_TEMPLATE=/devices/{device_id}/preview/frame
# Seconds before an outbound API request times out
API_TIMEOUT_SECONDS=30

# ── Local Flask settings ──────────────────────────────────────────────────────
# Port the local Flask service listens on (must match FLASK_PORT in electron-app/.env)
FLASK_PORT=5055
# Where captured images are stored on disk
IMAGE_DIR=./data/images
# Where log files are written
LOG_DIR=./data/logs
# Where the upload queue JSON file lives
QUEUE_FILE=./data/upload_queue.json

# LAN IP of this Pi — the API server uses this to POST grading results back
DEVICE_HOST=192.168.1.100

# ── Mode switch ───────────────────────────────────────────────────────────────
# production : grading pipeline — images uploaded to the API server for results
# training   : data collection — images uploaded to Roboflow for labelling
# NOTE: also set VITE_EDGE_MODE to the same value in electron-app/.env
EDGE_MODE=training
PRODUCTION_UPLOAD_TARGET=api
TRAINING_UPLOAD_TARGET=roboflow

# ── Roboflow (training mode only) ─────────────────────────────────────────────
# Required when EDGE_MODE=training and TRAINING_UPLOAD_TARGET=roboflow
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=
ROBOFLOW_DATASET_NAME=edge-captures
ROBOFLOW_PROJECT_NORMAL=rice-grading-normal
ROBOFLOW_PROJECT_IR=rice-grading-ir
# Optional legacy fallback: if set, both image types use this single project
ROBOFLOW_PROJECT=

# ── Worker behaviour ──────────────────────────────────────────────────────────
# How often the heartbeat worker pings the API server (seconds)
HEARTBEAT_INTERVAL_SECONDS=60
# How often the uploader polls the queue (seconds)
UPLOADER_POLL_SECONDS=3
# Max upload retries before an item is dead-lettered
UPLOADER_MAX_RETRIES=5

# ── Low-res preview relay (backend-mediated) ─────────────────────────────────
# When true, edge uploads low-res preview frames to backend only on active request
PREVIEW_RELAY_ENABLED=true
# Seconds between polling backend preview request state when idle
PREVIEW_REQUEST_POLL_SECONDS=2
# Frame rate while preview request is active (recommended 2-5 for Pi 3 B+)
PREVIEW_ACTIVE_FPS=3
# Optional override for local preview frame source
# PREVIEW_LOCAL_FRAME_URL=http://127.0.0.1:5055/preview/frame

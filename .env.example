DEVICE_ID=pi-001
DEVICE_SECRET=

# Local Flask settings
FLASK_PORT=5000
IMAGE_DIR=./data/images
LOG_DIR=/tmp/logs

# Mode switch used by kiosk + uploader
# production: upload scans to your API backend
# training: upload captures to Roboflow (or API if configured)
EDGE_MODE=production

# Upload target overrides (optional)
# If empty, defaults are:
# - production -> api
# - training -> roboflow
PRODUCTION_UPLOAD_TARGET=api
TRAINING_UPLOAD_TARGET=roboflow

# API backend
API_BASE_URL=https://your-api-server.com
API_UPLOAD_PATH=/scans
API_HEARTBEAT_PATH=/devices/heartbeat
API_TIMEOUT_SECONDS=30

# Roboflow training upload
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=
ROBOFLOW_PROJECT=
ROBOFLOW_DATASET_NAME=edge-captures

# Worker behavior
HEARTBEAT_INTERVAL_SECONDS=60
UPLOADER_POLL_SECONDS=3
UPLOADER_MAX_RETRIES=5

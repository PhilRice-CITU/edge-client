# =============================================================================
# Rice Vision — Edge Client Environment (local dev)
# Production Pis read this from ~/.config/Hum.ai/.env (seeded by .deb postinst).
# =============================================================================

# ── Device identity (auto-filled by Setup screen) ─────────────────────────────
DEVICE_ID=82b6db49-9fd7-454f-a21b-62fecbd3f6c5
DEVICE_SECRET=qYMVdsCdTedO5lEzHGFyTbPVDreGp7dZec5Hl7fKILs
DEVICE_DISPLAY_NAME=raspi-training-01
DEVICE_QR_URL=

# ── API server ────────────────────────────────────────────────────────────────
API_BASE_URL=https://hum-ai-zq6h9.ondigitalocean.app
API_TIMEOUT_SECONDS=30

# ── Local paths ───────────────────────────────────────────────────────────────
IMAGE_DIR=./data/images
LOG_DIR=./data/logs
CAPTURE_LOCK_FILE=/tmp/edge-capture.lock

# ── Mode switch ───────────────────────────────────────────────────────────────
EDGE_MODE=training
PRODUCTION_UPLOAD_TARGET=api
TRAINING_UPLOAD_TARGET=roboflow

# ── Roboflow (training mode only) ─────────────────────────────────────────────
ROBOFLOW_API_KEY=c32eqh0UKXsSvs8U2Iga
ROBOFLOW_WORKSPACE=humai-o2qtg
ROBOFLOW_PROJECT_NORMAL=rice-grading-normal
ROBOFLOW_PROJECT_IR=rice-grading-ir

# ── MQTT live connection ──────────────────────────────────────────────────────
MQTT_HOST=broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_TOPIC_PREFIX=ricevision
MQTT_KEEPALIVE_SECONDS=30
MQTT_TELEMETRY_INTERVAL_SECONDS=15
MQTT_CLIENT_ID=

# ── Safety ───────────────────────────────────────────────────────────────────
ALLOW_POWER_COMMANDS=false

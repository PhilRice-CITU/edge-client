# =============================================================================
# Rice Vision — Electron App Environment (edge-client/electron-app/.env)
# Copy to .env and fill in the values before running npm run dev or npm run start
# This file is read by Vite at build/dev time — VITE_ prefix is required for
# any variable that needs to be accessible in the renderer process.
# =============================================================================

# ── Mode switch ───────────────────────────────────────────────────────────────
# Controls which buttons appear in the Electron UI.
# production : only "Grade Rice" is shown
# training   : both "Grade Rice" and "Training Mode" are shown
# NOTE: keep in sync with EDGE_MODE in edge-client/.env
VITE_EDGE_MODE=production

# ── Local Flask port ──────────────────────────────────────────────────────────
# Must match FLASK_PORT in edge-client/.env
# Used by the main process to tell the renderer where to find the Flask API.
FLASK_PORT=5055
